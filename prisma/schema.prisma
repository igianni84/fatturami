generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enums ---

enum VatRegime {
  nazionale
  intraUE
  extraUE
}

enum InvoiceStatus {
  bozza
  emessa
  inviata
  parzialmente_pagata
  pagata
  scaduta
}

enum QuoteStatus {
  bozza
  inviato
  accettato
  rifiutato
  scaduto
  convertito
}

enum PurchaseInvoiceStatus {
  registrata
  pagata
}

enum ExpenseCategory {
  servizi_professionali
  software
  hardware
  viaggi
  telecomunicazioni
  trasporti
  pasti
  materiale_ufficio
  altro
}

enum TaxRateType {
  standard
  reduced
  minimum
  super_reduced
  reverse_charge
  export_exempt
}

// --- Models ---

model Company {
  id         String   @id @default(cuid())
  userId     String   @unique
  name       String
  nif        String
  address    String   @db.VarChar(1000)
  city       String   @default("")
  postalCode String   @default("")
  country    String   @default("ES")
  email      String   @default("")
  phone      String   @default("")
  iban       String   @default("")
  taxRegime  String   @default("")
  fiscalCode String   @default("")
  sdiCode    String   @default("")
  pec        String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Client {
  id              String     @id @default(cuid())
  userId          String
  name            String
  vatNumber       String     @default("")
  fiscalCode      String     @default("")
  address         String     @default("") @db.VarChar(1000)
  city            String     @default("")
  postalCode      String     @default("")
  country         String     @default("")
  email           String     @default("")
  currency        String     @default("EUR")
  vatRegime       VatRegime  @default(nazionale)
  notes           String     @default("") @db.VarChar(5000)
  viesValid       Boolean?
  viesValidatedAt DateTime?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  invoices Invoice[]
  quotes   Quote[]

  @@index([userId, deletedAt, name])
}

model Supplier {
  id              String          @id @default(cuid())
  userId          String
  name            String
  vatNumber       String          @default("")
  address         String          @default("") @db.VarChar(1000)
  city            String          @default("")
  postalCode      String          @default("")
  country         String          @default("")
  email           String          @default("")
  expenseCategory ExpenseCategory @default(altro)
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  purchaseInvoices PurchaseInvoice[]

  @@index([userId, deletedAt, name])
}

model TaxRate {
  id      String      @id @default(cuid())
  name    String
  rate    Decimal
  country String      @default("ES")
  type    TaxRateType @default(standard)

  invoiceLines  InvoiceLine[]
  quoteLines    QuoteLine[]
  creditNoteLines CreditNoteLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]
}

model Invoice {
  id           String        @id @default(cuid())
  userId       String
  number       String
  clientId     String
  date         DateTime
  dueDate      DateTime?
  status       InvoiceStatus @default(bozza)
  currency     String        @default("EUR")
  exchangeRate Decimal       @default(1)
  disclaimer   String        @default("") @db.VarChar(2000)
  notes        String        @default("") @db.VarChar(5000)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id])
  client      Client        @relation(fields: [clientId], references: [id])
  lines       InvoiceLine[]
  creditNotes CreditNote[]
  payments    Payment[]

  @@unique([userId, number])
  @@index([userId, status])
  @@index([clientId])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Decimal
  date      DateTime
  method    String   @default("") @db.VarChar(100)
  notes     String   @default("") @db.VarChar(1000)
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String  @db.Text
  quantity    Decimal
  unitPrice   Decimal
  taxRateId   String

  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxRate  TaxRate @relation(fields: [taxRateId], references: [id])

  @@index([invoiceId])
}

model CreditNote {
  id        String   @id @default(cuid())
  userId    String
  number    String
  invoiceId String
  date      DateTime
  notes     String   @default("") @db.VarChar(5000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id])
  invoice Invoice          @relation(fields: [invoiceId], references: [id])
  lines   CreditNoteLine[]

  @@unique([userId, number])
  @@index([userId, invoiceId])
}

model CreditNoteLine {
  id           String  @id @default(cuid())
  creditNoteId String
  description  String  @db.Text
  quantity     Decimal
  unitPrice    Decimal
  taxRateId    String

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  taxRate    TaxRate    @relation(fields: [taxRateId], references: [id])

  @@index([creditNoteId])
}

model Quote {
  id         String      @id @default(cuid())
  userId     String
  number     String
  clientId   String
  date       DateTime
  expiryDate DateTime?
  status     QuoteStatus @default(bozza)
  notes      String      @default("") @db.VarChar(5000)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user   User        @relation(fields: [userId], references: [id])
  client Client      @relation(fields: [clientId], references: [id])
  lines  QuoteLine[]

  @@unique([userId, number])
  @@index([userId, status])
  @@index([clientId])
}

model QuoteLine {
  id          String  @id @default(cuid())
  quoteId     String
  description String  @db.Text
  quantity    Decimal
  unitPrice   Decimal
  taxRateId   String

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  taxRate TaxRate @relation(fields: [taxRateId], references: [id])

  @@index([quoteId])
}

model PurchaseInvoice {
  id         String                @id @default(cuid())
  userId     String
  supplierId String
  number     String
  date       DateTime
  category   ExpenseCategory       @default(altro)
  status     PurchaseInvoiceStatus @default(registrata)
  filePath   String?
  notes      String                @default("") @db.VarChar(5000)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  user     User                  @relation(fields: [userId], references: [id])
  supplier Supplier              @relation(fields: [supplierId], references: [id])
  lines    PurchaseInvoiceLine[]

  @@index([userId, status])
  @@index([supplierId])
}

model PurchaseInvoiceLine {
  id                String  @id @default(cuid())
  purchaseInvoiceId String
  description       String  @db.Text
  amount            Decimal
  taxRateId         String
  deductible        Boolean @default(true)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  taxRate         TaxRate         @relation(fields: [taxRateId], references: [id])

  @@index([purchaseInvoiceId])
}

model Expense {
  id          String          @id @default(cuid())
  userId      String
  date        DateTime
  description String          @db.Text
  amount      Decimal
  category    ExpenseCategory @default(altro)
  taxAmount   Decimal         @default(0)
  deductible  Boolean         @default(true)
  filePath    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  email      String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companies        Company[]
  clients          Client[]
  suppliers        Supplier[]
  invoices         Invoice[]
  quotes           Quote[]
  creditNotes      CreditNote[]
  purchaseInvoices PurchaseInvoice[]
  expenses         Expense[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
