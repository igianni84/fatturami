# Database (PostgreSQL — local dev or Supabase)
DATABASE_URL="postgresql://invoicing:invoicing@localhost:5432/invoicing"
DIRECT_URL="postgresql://invoicing:invoicing@localhost:5432/invoicing"

# Supabase (server-side)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Supabase (client-side — NEXT_PUBLIC_ prefix exposes to browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# AI (optional - needed for PDF extraction)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

